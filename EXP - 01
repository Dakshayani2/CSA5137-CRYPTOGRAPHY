#include <stdio.h>

int main() {
    char text[100];
    int k, i;

    printf("Enter text: ");
    scanf("%s", text);

    printf("Enter shift (1-25): ");
    scanf("%d", &k);

    for (i = 0; text[i] != '\0'; i++) {
        if (text[i] >= 'a' && text[i] <= 'z') {
            text[i] = ((text[i] - 'a' + k) % 26) + 'a';
        }
        else if (text[i] >= 'A' && text[i] <= 'Z') {
            text[i] = ((text[i] - 'A' + k) % 26) + 'A';
        }
    }

    printf("Encrypted: %s", text);

    return 0;
}

