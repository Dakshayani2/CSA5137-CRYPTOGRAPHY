#include <stdio.h>
#include <string.h>

int modInverse(int a) {
    for(int i = 0; i < 26; i++)
        if((a * i) % 26 == 1)
            return i;
    return -1;
}

int main() {
    int freq[26] = {0};
    char cipher[500];
    int i, max1 = 0, max2 = 0;

    printf("Enter ciphertext: ");
    scanf(" %[^\n]", cipher);

    for(i = 0; cipher[i]; i++)
        if(cipher[i] >= 'A' && cipher[i] <= 'Z')
            freq[cipher[i] - 'A']++;

    for(i = 0; i < 26; i++) {
        if(freq[i] > freq[max1]) {
            max2 = max1;
            max1 = i;
        } else if(freq[i] > freq[max2] && i != max1) {
            max2 = i;
        }
    }

    int c1 = max1, c2 = max2;
    int p1 = 'E' - 'A';
    int p2 = 'T' - 'A';

    int a = ((c1 - c2 + 26) % 26);
    int b = (c1 - a * p1 + 26*26) % 26;

    int inv = modInverse(a);
    if(inv == -1) {
        printf("Invalid key.\n");
        return 0;
    }

    for(i = 0; cipher[i]; i++) {
        if(cipher[i] >= 'A' && cipher[i] <= 'Z')
            cipher[i] = ((inv * (cipher[i] - 'A' - b + 26)) % 26) + 'A';
    }

    printf("Decrypted Text: %s\n", cipher);
    return 0;
}
